{
  "name": "@aeon-memory/opencode",
  "version": "0.7.2",
  "description": "Automatic Aeon Memory lifecycle integration for OpenCode",
  "type": "module",
  "license": "MIT",
  "exports": {
    ".": "./dist/aeon-memory.js",
    "./server": "./dist/aeon-memory.js"
  },
  "bin": {
    "aeon-memory-opencode": "dist/cli.js"
  },
  "files": [
    "dist/",
    "README.md",
    "README_CN.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HuChundong/aeon-memory.git",
    "directory": "integrations/opencode"
  },
  "homepage": "https://github.com/HuChundong/aeon-memory#opencode-集成",
  "bugs": {
    "url": "https://github.com/HuChundong/aeon-memory/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "typecheck": "tsc --noEmit",
    "build": "npm run clean && esbuild src/aeon-memory.ts src/cli.ts --bundle --platform=node --format=esm --target=node22 --outdir=dist --outbase=src",
    "test": "npm run build && tsx --test test/*.test.ts",
    "pack:check": "npm run build && npm pack --dry-run",
    "prepack": "npm run build"
  },
  "engines": {
    "node": ">=22"
  },
  "opencode": {
    "minimumVersion": "1.17.18",
    "testedThroughVersion": "1.17.20"
  },
  "keywords": [
    "opencode",
    "memory",
    "agent",
    "aeon-memory"
  ],
  "devDependencies": {
    "@opencode-ai/plugin": "1.18.4",
    "@types/node": "^26.1.1",
    "esbuild": "^0.28.1",
    "tsx": "^4.20.0",
    "typescript": "^7.0.2"
  },
  "dependencies": {
    "jsonc-parser": "3.3.1"
  }
}
