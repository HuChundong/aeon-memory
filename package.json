{
  "name": "@aeon-memory/data-tools",
  "version": "0.6.2",
  "private": true,
  "description": "Private offline data inspection and export tools for Aeon Memory",
  "type": "module",
  "bin": {
    "export-tencent-vdb": "./bin/export-tencent-vdb.mjs",
    "read-local-memory": "./bin/read-local-memory.mjs"
  },
  "scripts": {
    "build": "npm run build:export && npm run build:reader",
    "build:export": "tsc -p scripts/export-tencent-vdb/tsconfig.json",
    "build:reader": "tsc -p scripts/read-local-memory/tsconfig.json",
    "export-tencent-vdb": "node ./bin/export-tencent-vdb.mjs",
    "read-local-memory": "node ./bin/read-local-memory.mjs"
  },
  "license": "MIT",
  "engines": { "node": ">=22.16.0" },
  "dependencies": {
    "sqlite-vec": "0.1.9"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^7.0.2"
  }
}
